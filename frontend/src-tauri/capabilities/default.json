{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/video-intake-fastapi-sidecar-dev",
          "cmd": "video-intake-fastapi-sidecar-dev",
          "sidecar": true,
          "args": []
        }
      ]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "url": "obsidian://*"
        },
        {
          "url": "obsidian://**"
        }
      ]
    }
  ]
}
