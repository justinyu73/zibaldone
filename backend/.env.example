# 本 vault 的絕對路徑（WSL control plane）
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian-vault

# Vault 內存放筆記的子資料夾（會自動建立）
# 預設遵循 vault 慣例：外部資訊落到 note_study/02_Sources/<source>/
OBSIDIAN_SUBFOLDER=note_study/02_Sources/youtube

# OpenAI API Key（選填；留空時翻譯功能停用）
OPENAI_API_KEY=

# Legacy fallback model（選填；task-specific model 會優先）
OPENAI_MODEL=gpt-5-mini

# YT API 啟用模型策略
# 詳細預設在 backend/enabled_models.json；以下 env 可覆蓋各任務模型。
OPENAI_TRANSLATE_MODEL=gpt-5-mini
OPENAI_SUMMARY_MODEL=gpt-5.2
OPENAI_FUSION_RESEARCH_MODEL=gpt-5.2
OPENAI_DRAFT_BULK_MODEL=gpt-5-mini

# 本地 whisper.cpp ASR runtime 根目錄（語音 lane）。binary/model 不進 git，
# 用 backend/setup_asr_runtime.sh build 到此處（預設 ~/.config/yt-note-app）。
YT_NOTE_ASR_ROOT=

# 真實 provider runtime 已限定為 operator-supplied media；平台下載與 durable write 仍不啟用。
OPENAI_ASR_MODEL=gpt-4o-transcribe
OPENAI_ASR_BULK_MODEL=gpt-4o-mini-transcribe
OPENAI_ASR_DIARIZE_MODEL=gpt-4o-transcribe-diarize
OPENAI_OCR_VISUAL_MODEL=gpt-5.2

# CORS 允許來源
FRONTEND_ORIGIN=http://127.0.0.1:8765
